############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
# 你必須在上線前更換這些密鑰
# Run: sh utils/generate-keys.sh to generate new keys
# 執行: sh utils/generate-keys.sh 來產生新密鑰
############

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjE4NTgwMDAwMDB9.placeholder
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MTg1ODAwMDAwMH0.placeholder
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated
SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters-long-replace-me-please
VAULT_ENC_KEY=your-vault-encryption-key-hex
PG_META_CRYPTO_KEY=your-pg-meta-crypto-key
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-logflare-public-access-token
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-logflare-private-access-token


############
# Database - You can change these to any PostgreSQL database that has logical replication enabled.
# 資料庫 - 可以更換為任何支持邏輯複製的 PostgreSQL 資料庫
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# default user is postgres


############
# Supavisor -- Database pooler
# Supavisor -- 資料庫連線池
############
# Port Supavisor listens on for transaction pooling connections
# Supavisor 用於交易連線池的監聽埠
POOLER_PROXY_PORT_TRANSACTION=6543
# Maximum number of PostgreSQL connections Supavisor opens per pool
# Supavisor 每個連線池打開的最大 PostgreSQL 連線數
POOLER_DEFAULT_POOL_SIZE=20
# Maximum number of client connections Supavisor accepts per pool
# Supavisor 每個連線池接受的最大客戶端連線數
POOLER_MAX_CLIENT_CONN=100
# Unique tenant identifier
# 唯一租戶識別碼
POOLER_TENANT_ID=your-tenant-id
# Pool size for internal metadata storage used by Supavisor
# Supavisor 內部元資料使用的連線池大小
POOLER_DB_POOL_SIZE=5


############
# API Proxy - Configuration for the Kong Reverse proxy.
# API 代理 - Kong 反向代理設定
############

KONG_HTTP_PORT=8100
KONG_HTTPS_PORT=8543


############
# API - Configuration for PostgREST.
# API - PostgREST 設定
############

PGRST_DB_SCHEMAS=public,storage,graphql_public


############
# Auth - Configuration for the GoTrue authentication server.
# 認證 - GoTrue 認證伺服器設定
############

## General / 一般設定
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://localhost:8100

## Mailer Config / 郵件設定
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Email auth / 電子郵件認證
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Phone auth / 手機認證
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true


############
# Studio - Configuration for the Dashboard
# Studio - 儀表板設定
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# replace if you intend to use Studio outside of localhost
# 如果你打算在 localhost 以外使用 Studio，請替換此值
SUPABASE_PUBLIC_URL=http://localhost:8100

# Enable webp support / 啟用 webp 支援
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Add your OpenAI API key to enable SQL Editor Assistant
# 加入 OpenAI API Key 以啟用 SQL 編輯器助手
OPENAI_API_KEY=


############
# Functions - Configuration for Functions
# 函數 - Edge Functions 設定
############
# NOTE: VERIFY_JWT applies to all functions. Per-function VERIFY_JWT is not supported yet.
# 注意: VERIFY_JWT 適用於所有函數。尚不支援個別函數的 VERIFY_JWT 設定。
FUNCTIONS_VERIFY_JWT=false


############
# Logs - Configuration for Analytics
# 日誌 - 分析設定
# Please refer to https://supabase.com/docs/reference/self-hosting-analytics/introduction
############

# Docker socket location - this value will differ depending on your OS
# Docker socket 位置 - 此值會因作業系統不同而異
# For Podman: /run/user/1000/podman/podman.sock
# For Docker: /var/run/docker.sock
DOCKER_SOCKET_LOCATION=/run/user/1000/podman/podman.sock

# Google Cloud Project details (for BigQuery backend)
# Google Cloud 專案設定（用於 BigQuery 後端）
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
